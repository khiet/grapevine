{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grapevine",
  "version": "../package.json",
  "identifier": "com.khietle.grapevine",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVDRTlEREI2OUIyNDU3RkYKUldUL1Z5U2J0dDNwWEovM1hCRkwyU0FDa3lWQXRTd2Y3cDBGeWhyeVJQSlFZZmd0VjQ2QVBwV2oK",
      "endpoints": [
        "https://github.com/khiet/grapevine/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Grapevine",
        "width": 440,
        "height": 680,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
